<Window x:Class="Agent.UI.ReasonDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Reason for Stopping Tracker" Height="270" Width="400"
        Background="{StaticResource BackgroundBrush}"
        WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True" WindowStartupLocation="CenterOwner">
    
    <Border BorderBrush="#1F2937" BorderThickness="1.5" CornerRadius="12" Background="{StaticResource BackgroundBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <!-- Title Bar -->
                <RowDefinition Height="35"/>
                <!-- Main Body -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Grid Grid.Row="0" Background="#111827" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <TextBlock Text="Stop Session Reason" Foreground="#9CA3AF" FontSize="11" FontWeight="Bold" Margin="16,0,0,0" VerticalAlignment="Center"/>
                <Button Content="✕" HorizontalAlignment="Right" Width="30" Height="25" Background="Transparent" Foreground="#EF4444" BorderBrush="Transparent" Click="Cancel_Click" Cursor="Hand" Margin="0,0,8,0"/>
            </Grid>

            <!-- Main Body -->
            <StackPanel Grid.Row="1" Margin="20,15,20,15">
                <!-- Statistics Block -->
                <Border BorderBrush="#1F2937" BorderThickness="1" CornerRadius="8" Background="#111827" Padding="12,8" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="WORKING TIME" Foreground="#10B981" FontSize="9" FontWeight="Bold"/>
                            <TextBlock x:Name="TxtWorkingTime" Text="00h 00m 00s" Foreground="#F3F4F6" FontSize="14" FontWeight="Bold" Margin="0,2,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="IDLE TIME" Foreground="#F59E0B" FontSize="9" FontWeight="Bold"/>
                            <TextBlock x:Name="TxtIdleTime" Text="00h 00m 00s" Foreground="#F3F4F6" FontSize="14" FontWeight="Bold" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <TextBlock Text="Please enter the reason for stopping the tracker:" Foreground="#F3F4F6" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
                
                <TextBox x:Name="TxtReason" Background="#111827" Foreground="#F3F4F6" BorderBrush="#374151" CaretBrush="#6366F1" Padding="8,6" FontSize="12" Margin="0,0,0,15" KeyDown="TxtReason_KeyDown"/>
                
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Button Grid.Column="0" Content="Submit" Background="#6366F1" Foreground="#F3F4F6" BorderBrush="#6366F1" Padding="8" FontSize="12" FontWeight="Bold" Cursor="Hand" Click="Submit_Click"/>
                    <Button Grid.Column="2" Content="Cancel" Background="Transparent" Foreground="#9CA3AF" BorderBrush="#374151" Padding="8" FontSize="12" FontWeight="Bold" Cursor="Hand" Click="Cancel_Click"/>
                </Grid>
            </StackPanel>
        </Grid>
    </Border>
</Window>

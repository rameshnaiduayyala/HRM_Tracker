<Application x:Class="Agent.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Agent.UI">
    <Application.Resources>
         <!-- Global Application Styles (Dark Theme Colors) -->
         <SolidColorBrush x:Key="BackgroundBrush" Color="#0B0F19"/>
         <SolidColorBrush x:Key="CardBrush" Color="#111827"/>
         <SolidColorBrush x:Key="TextBrush" Color="#F3F4F6"/>
         <SolidColorBrush x:Key="MutedTextBrush" Color="#9CA3AF"/>
         <SolidColorBrush x:Key="PrimaryBrush" Color="#6366F1"/>
         <SolidColorBrush x:Key="SuccessBrush" Color="#10B981"/>
         <SolidColorBrush x:Key="DangerBrush" Color="#EF4444"/>
         <SolidColorBrush x:Key="WarningBrush" Color="#F59E0B"/>
    </Application.Resources>
</Application>

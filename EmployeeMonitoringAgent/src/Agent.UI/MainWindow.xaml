<Window x:Class="Agent.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TaskTracky Desktop Agent" Height="650" Width="720"
        Background="{StaticResource BackgroundBrush}"
        WindowStyle="None" ResizeMode="CanResize"
        AllowsTransparency="True" WindowStartupLocation="CenterScreen">
    
    <Border BorderBrush="#1F2937" BorderThickness="1" CornerRadius="12" Background="{StaticResource BackgroundBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <!-- Title Bar -->
                <RowDefinition Height="40"/>
                <!-- Main Body -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Frameless Title Bar -->
            <Grid Grid.Row="0" Background="#111827" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                    <TextBlock Text="taskTracky" Foreground="#6366F1" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                    <TextBlock Text=" | Windows Agent" Foreground="#9CA3AF" FontSize="12" Margin="6,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,8,0" VerticalAlignment="Center">
                    <Button Content="—" Width="30" Height="25" Background="Transparent" Foreground="#F3F4F6" BorderBrush="Transparent" Click="Minimize_Click" Cursor="Hand"/>
                    <Button Content="✕" Width="30" Height="25" Background="Transparent" Foreground="#EF4444" BorderBrush="Transparent" Click="Close_Click" Cursor="Hand" Margin="4,0,0,0"/>
                </StackPanel>
            </Grid>

            <!-- Main Content Area -->
            <Grid Grid.Row="1" Margin="20">
                <!-- 1. Authentication View -->
                <Grid x:Name="AuthView" Visibility="Visible" VerticalAlignment="Center" HorizontalAlignment="Center" Width="360">
                    <StackPanel>
                        <TextBlock Text="Sign In to taskTracky" Foreground="#F3F4F6" FontWeight="Bold" FontSize="20" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        
                        <StackPanel>
                            <TextBlock Text="Server API URL" Foreground="#9CA3AF" FontSize="11" Margin="0,0,0,4"/>
                            <TextBox x:Name="TxtServerUrl" Text="http://localhost:5000" Background="#111827" Foreground="#F3F4F6" BorderBrush="#374151" Padding="8,6" FontSize="12"/>
                        </StackPanel>

                        <StackPanel Margin="0,10,0,0">
                            <TextBlock Text="Employee Email" Foreground="#9CA3AF" FontSize="11" Margin="0,0,0,4"/>
                            <TextBox x:Name="TxtEmail" Text="employee@acme.com" Background="#111827" Foreground="#F3F4F6" BorderBrush="#374151" Padding="8,6" FontSize="12"/>
                        </StackPanel>

                        <StackPanel Margin="0,10,0,0">
                            <TextBlock Text="Password" Foreground="#9CA3AF" FontSize="11" Margin="0,0,0,4"/>
                            <PasswordBox x:Name="TxtPassword" Password="employee123" Background="#111827" Foreground="#F3F4F6" BorderBrush="#374151" Padding="8,6" FontSize="12"/>
                        </StackPanel>

                        <TextBlock x:Name="TxtAuthError" Foreground="#EF4444" FontSize="11" TextWrapping="Wrap" HorizontalAlignment="Center" Margin="0,5,0,0"/>

                        <Button Content="Connect &amp; Authenticate" Background="#6366F1" Foreground="#F3F4F6" BorderBrush="#6366F1" Padding="12" FontSize="13" FontWeight="Bold" Cursor="Hand" Click="Login_Click" Margin="0,15,0,0">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- 2. Dashboard View -->
                <Grid x:Name="DashboardView" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <!-- Status Bars / Warning Banners -->
                        <RowDefinition Height="Auto"/>
                        <!-- Profile Card & Configs -->
                        <RowDefinition Height="Auto"/>
                        <!-- Operations Controls -->
                        <RowDefinition Height="Auto"/>
                        <!-- Real-time telemetry metrics -->
                        <RowDefinition Height="Auto"/>
                        <!-- Logs Console -->
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Warning Banners -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,12">
                        <!-- Security Status Banner -->
                        <Border x:Name="SecurityStatusBanner" BorderBrush="#10B981" BorderThickness="1" CornerRadius="8" Padding="10,8" Margin="0,0,0,8" Visibility="Visible">
                            <Border.Background>
                                <SolidColorBrush Color="#10B981" Opacity="0.15"/>
                            </Border.Background>
                            <TextBlock Text="🛡️ Agent integrity verified. Secure connection active." Foreground="#6EE7B7" FontSize="12"/>
                        </Border>

                        <!-- Update Available Banner -->
                        <Border x:Name="UpdateAvailableBanner" BorderBrush="#6366F1" BorderThickness="1" CornerRadius="8" Padding="10,8" Margin="0,0,0,8" Visibility="Collapsed">
                            <Border.Background>
                                <SolidColorBrush Color="#6366F1" Opacity="0.15"/>
                            </Border.Background>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔄 Update Available:" Foreground="#C7D2FE" FontWeight="Bold" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TxtUpdateVersion" Text="" Foreground="#C7D2FE" FontSize="12" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="Update" Background="#6366F1" Foreground="White" BorderBrush="Transparent" Padding="8,4" FontSize="11" Click="Update_Click" Cursor="Hand"/>
                            </Grid>
                        </Border>

                        <!-- Offline Queue Banner -->
                        <Border x:Name="OfflineSyncBanner" BorderBrush="#F59E0B" BorderThickness="1" CornerRadius="8" Padding="10,8" Margin="0,0,0,8" Visibility="Collapsed">
                            <Border.Background>
                                <SolidColorBrush Color="#F59E0B" Opacity="0.15"/>
                            </Border.Background>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚠️ Offline Mode:" Foreground="#F59E0B" FontWeight="Bold" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TxtOfflineCount" Text=" 0 events queued locally." Foreground="#F59E0B" FontSize="12" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="Sync Now" Background="#D97706" Foreground="White" BorderBrush="Transparent" Padding="8,4" FontSize="11" Click="SyncOffline_Click" Cursor="Hand"/>
                            </Grid>
                        </Border>

                        <!-- Clock In Reminder Banner -->
                        <Border x:Name="ClockInReminderBanner" BorderBrush="#EF4444" BorderThickness="1" CornerRadius="8" Padding="10,8" Margin="0,0,0,8" Visibility="Visible">
                            <Border.Background>
                                <SolidColorBrush Color="#EF4444" Opacity="0.15"/>
                            </Border.Background>
                            <TextBlock Text="⚠️ Please Clock In to start tracking your mandatory 8-hour shift." Foreground="#F87171" FontSize="12"/>
                        </Border>

                        <!-- Start Tracker Reminder Banner -->
                        <Border x:Name="StartTrackerReminderBanner" BorderBrush="#6366F1" BorderThickness="1" CornerRadius="8" Padding="10,8" Margin="0,0,0,8" Visibility="Collapsed">
                            <Border.Background>
                                <SolidColorBrush Color="#6366F1" Opacity="0.15"/>
                            </Border.Background>
                            <TextBlock Text="ℹ️ Clocked In. Click Start Tracker to begin recording work hours." Foreground="#C7D2FE" FontSize="12"/>
                        </Border>
                    </StackPanel>

                    <!-- Profile Card & Configs Panel -->
                    <Grid Grid.Row="1" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Profile Details -->
                        <Border Grid.Column="0" Background="#111827" BorderBrush="#1F2937" BorderThickness="1" CornerRadius="12" Padding="12,10" Margin="0,0,6,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock x:Name="TxtProfileName" Text="Jane Doe" Foreground="#F3F4F6" FontWeight="Bold" FontSize="13"/>
                                    <TextBlock x:Name="TxtProfileEmail" Text="jane@acme.com" Foreground="#9CA3AF" FontSize="10" Margin="0,2,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="Sign Out" Background="#374151" Foreground="White" BorderBrush="Transparent" Padding="8,4" FontSize="10" Click="Logout_Click" Cursor="Hand" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Configurations -->
                        <Border Grid.Column="1" Background="#111827" BorderBrush="#1F2937" BorderThickness="1" CornerRadius="12" Padding="12,10" Margin="6,0,0,0">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Auto-Start on Startup" Foreground="#F3F4F6" FontSize="11" VerticalAlignment="Center"/>
                                    <CheckBox Grid.Column="1" x:Name="ChkAutoStart" Click="AutoStart_Click" Cursor="Hand" VerticalAlignment="Center"/>
                                </Grid>
                                <TextBlock x:Name="TxtWorkstation" Text="Workstation: Unknown" Foreground="#9CA3AF" FontSize="9" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Operations Controls -->
                    <Border Grid.Row="2" Background="#111827" BorderBrush="#1F2937" BorderThickness="1" CornerRadius="12" Padding="12" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                <TextBlock Text="Attendance Shift" Foreground="#9CA3AF" FontSize="10" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                <Button x:Name="BtnClockToggle" Content="Clock In" Background="#10B981" Foreground="White" BorderBrush="Transparent" Padding="10" FontSize="12" FontWeight="Bold" Cursor="Hand" Click="ClockToggle_Click"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="6,0,6,0">
                                <TextBlock Text="Work Tracker" Foreground="#9CA3AF" FontSize="10" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                <Button x:Name="BtnSessionToggle" Content="Start Tracker" Background="#4b5563" Foreground="White" BorderBrush="Transparent" Padding="10" FontSize="12" FontWeight="Bold" Cursor="No" IsEnabled="False" Click="SessionToggle_Click"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Margin="6,0,0,0">
                                <TextBlock Text="Break Status" Foreground="#9CA3AF" FontSize="10" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                <ComboBox x:Name="CboBreakReason" SelectedIndex="0" Background="#374151" Foreground="White" BorderBrush="#374151" Padding="8,6" FontSize="12" SelectionChanged="BreakReason_SelectionChanged">
                                    <ComboBoxItem Content="Working"/>
                                    <ComboBoxItem Content="Lunch Break"/>
                                    <ComboBoxItem Content="Meeting"/>
                                    <ComboBoxItem Content="Personal Break"/>
                                </ComboBox>
                                <TextBlock x:Name="TxtBreakStatus" Text="" Foreground="#F59E0B" FontSize="9" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Real-Time Metrics Panel -->
                    <Grid Grid.Row="3" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Focus Window Card -->
                        <Border Grid.Column="0" Background="#111827" BorderBrush="#1F2937" BorderThickness="1" CornerRadius="12" Padding="12" Margin="0,0,6,0">
                            <StackPanel>
                                <TextBlock Text="ACTIVE WINDOW" Foreground="#818CF8" FontWeight="Bold" FontSize="10"/>
                                <TextBlock x:Name="TxtActiveApp" Text="-" Foreground="#F3F4F6" FontSize="13" FontWeight="Bold" Margin="0,6,0,2"/>
                                <TextBlock x:Name="TxtWindowTitle" Text="-" Foreground="#9CA3AF" FontSize="10" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Border>

                        <!-- Idle Card -->
                        <Border Grid.Column="1" Background="#111827" BorderBrush="#1F2937" BorderThickness="1" CornerRadius="12" Padding="12" Margin="6,0,6,0">
                            <StackPanel>
                                <TextBlock Text="IDLE TIME" Foreground="#9CA3AF" FontSize="10"/>
                                <TextBlock x:Name="TxtIdleTime" Text="0s" Foreground="#F3F4F6" FontSize="18" FontWeight="Bold" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Tracked Card -->
                        <Border Grid.Column="2" Background="#111827" BorderBrush="#1F2937" BorderThickness="1" CornerRadius="12" Padding="12" Margin="6,0,6,0">
                            <StackPanel>
                                <TextBlock Text="SHIFT LOGGED" Foreground="#10B981" FontSize="10"/>
                                <TextBlock x:Name="TxtTrackedTime" Text="00h 00m 00s" Foreground="#F3F4F6" FontSize="18" FontWeight="Bold" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Remaining Card -->
                        <Border Grid.Column="3" Background="#111827" BorderBrush="#1F2937" BorderThickness="1" CornerRadius="12" Padding="12" Margin="6,0,0,0">
                            <StackPanel>
                                <TextBlock Text="REMAINING TIME" Foreground="#F59E0B" FontSize="10" FontWeight="Bold"/>
                                <TextBlock x:Name="TxtRemainingTime" Text="08h 00m 00s" Foreground="#F3F4F6" FontSize="18" FontWeight="Bold" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Logger Console -->
                    <Grid Grid.Row="4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="TELEMETRY LOG CONSOLE" Foreground="#9CA3AF" FontSize="10" Margin="0,0,0,4"/>
                        <ListBox Grid.Row="1" x:Name="LstLogs" Background="#030712" BorderBrush="#1F2937" Foreground="#10B981" FontFamily="Consolas" FontSize="11" Padding="6"/>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>

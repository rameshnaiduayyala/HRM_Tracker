{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EmployeeTrackerAgent",
  "version": "1.0.0",
  "identifier": "com.enterprise.employeetracker.agent",
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "app": {
    "windows": [
      {
        "title": "Employee Productivity Tracker",
        "width": 1024,
        "height": 768,
        "resizable": true,
        "fullscreen": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "plugins": {
    "updater": {
      "pubkey": "tauri-updater-public-key-placeholder"
    }
  }
}
